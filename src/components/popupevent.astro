---
import Chatroom from "./chatroom.astro";
---

<!-- Zone d'action du popup avec Alpine.js -->
<section
  x-data="{
    isOpen: false,
    selectedEvent: null,
    view: 'details',
    isOngoing(event) {
      if (!event) return false;
      const now = Date.now();
      const start = new Date(event.start_datetime).getTime();
      const end = new Date(event.end_datetime).getTime();
      const margin = 3600000; // 1h de marge avant/après l'événement
      return start - margin <= now && now <= end + margin;
    }
  }"
>
  <slot />

  <!-- popup avec Alpine.js -->
  <div
    x-show="isOpen"
    class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50"
    x-transition:opacity
    @click.self="isOpen = false"
    x-cloak
  >
    <div
      x-show="isOpen"
      id="popup-content"
      class="rounded-lg w-full mx-2 max-w-2xl"
      style="background: linear-gradient(to bottom, #1f191d, #121012);"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0 scale-90"
      x-transition:enter-end="opacity-100 scale-100"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100 scale-100"
      x-transition:leave-end="opacity-0 scale-90"
      x-cloak
    >
      <!-- Détail de l'événement -->
      <template x-if="view === 'details' && selectedEvent">
        <div class="border border-gray-300 p-6 rounded-lg shadow-lg w-full">
          <h2 class="text-2xl font-bold mb-4 font-heading text-heading leading-tight" x-text="selectedEvent.title"></h2>
          <p class="mb-4" x-text="selectedEvent.description"></p>
          <p><strong>Capacity:</strong> <span x-text="selectedEvent.players_count ?? 'Unlimited'"></span></p>
          <p><strong>Organizer:</strong> <span x-text="selectedEvent.organisateur"></span></p>
          <p><strong>Start:</strong> <span x-text="new Date(selectedEvent.start_datetime).toLocaleString()"></span></p>
          <p><strong>End:</strong> <span x-text="new Date(selectedEvent.end_datetime).toLocaleString()"></span></p>

          <div class="flex justify-between mt-10">
            <div x-show="connected">
              <div class="flex gap-2">
                <!-- Bouton favoris -->
                <button
                  @click="Alpine.store('favorites').toggle(selectedEvent.id)"
                  class="px-4 py-2 text-white rounded transition-colors select-none"
                  :class="Alpine.store('favorites').has(selectedEvent.id) ? 'bg-red-600 hover:bg-red-700' : 'bg-blue-500 hover:bg-blue-600'"
                  x-text="Alpine.store('favorites').has(selectedEvent.id) ? 'Forget it' : `I'm in`"
                ></button>

                <!-- Bouton Rejoindre -->
                <button
                  x-show="isOngoing(selectedEvent)"
                  @click="view = 'chat'"
                  class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700 transition-colors select-none"
                >
                  Join
                </button>
              </div>
            </div>
            <!-- Bouton Fermer -->
            <button
              @click="isOpen = false"
              class="ml-auto bg-red-700 text-white px-4 py-2 rounded hover:bg-red-800 transition-colors select-none"
            >
              Close
            </button>
          </div>
        </div>
      </template>

      <!-- Chat éphémère P2P -->
      <Chatroom />
    </div>
  </div>
</section>
