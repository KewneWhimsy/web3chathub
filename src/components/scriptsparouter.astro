<script>
  // Identifiant du conteneur échangé entre les "pages" (cf. layout.astro, id="chatcontain")
  const SWAP_ID = "chatcontain";

  function isLocalLink(link: HTMLAnchorElement): boolean {
    if (link.target && link.target !== "_self") return false;
    if (link.hasAttribute("download")) return false;
    if (link.origin !== window.location.origin) return false;
    return true;
  }

  // Les <script> insérés via innerHTML ne s'exécutent jamais : on les recrée pour forcer leur exécution
  function reviveScripts(container: Element): void {
    container.querySelectorAll("script").forEach((oldScript) => {
      const newScript = document.createElement("script");
      for (const attr of Array.from(oldScript.attributes)) {
        newScript.setAttribute(attr.name, attr.value);
      }
      newScript.textContent = oldScript.textContent;
      oldScript.replaceWith(newScript);
    });
  }

  async function navigateTo(url: string, push: boolean): Promise<void> {
    const current = document.getElementById(SWAP_ID);
    if (!current) {
      window.location.href = url;
      return;
    }

    let html: string;
    try {
      const response = await fetch(url);
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      html = await response.text();
    } catch (error) {
      console.error("Navigation SPA échouée, fallback en navigation classique:", error);
      window.location.href = url;
      return;
    }

    const parsed = new DOMParser().parseFromString(html, "text/html");
    const next = parsed.getElementById(SWAP_ID);
    if (!next) {
      window.location.href = url;
      return;
    }

    document.title = parsed.title;
    current.replaceWith(next);
    reviveScripts(next);

    if (window.htmx) {
      window.htmx.process(next);
    }

    if (push) {
      history.pushState({}, "", url);
    }

    window.scrollTo(0, 0);
    // Permet aux scripts de page basés sur DOMContentLoaded (ex: contact.astro) de se ré-initialiser
    document.dispatchEvent(new Event("DOMContentLoaded"));
  }

  document.body.addEventListener("click", (event) => {
    if (event.defaultPrevented || event.button !== 0) return;
    if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

    const target = event.target as Element | null;
    const link = target?.closest("a");
    if (!(link instanceof HTMLAnchorElement) || !isLocalLink(link)) return;

    // Lien d'ancrage vers la page courante : laissé au navigateur
    if (link.pathname === window.location.pathname && link.hash) return;

    event.preventDefault();
    navigateTo(link.href, true);
  });

  window.addEventListener("popstate", () => {
    navigateTo(window.location.href, false);
  });
</script>
